# Google Analytics 4
NEXT_PUBLIC_GA4_ID=

# Google Ads conversion tracking
NEXT_PUBLIC_GADS_ID=
NEXT_PUBLIC_GADS_CONVERSION_LABEL=

# Cloudflare Turnstile (bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_VERIFY_URL=

# Google Ads conversion value (USD, used for Smart Bidding)
NEXT_PUBLIC_GADS_CONVERSION_VALUE=100

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Google Search Console verification token
NEXT_PUBLIC_GSC_VERIFICATION=

# Firebase (lead backup storage)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# EmailJS (contact form notifications + confirmation emails)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_CONFIRM_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Executive dashboard access code (optional, defaults to 'ra2026')
NEXT_PUBLIC_EXEC_ACCESS_CODE=

# Sentry error monitoring (optional — errors log to console if not set)
NEXT_PUBLIC_SENTRY_DSN=
